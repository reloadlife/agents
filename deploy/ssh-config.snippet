# Add to ~/.ssh/config on your client (only needed for --ssh fallback)

Host agents
  HostName YOUR_AGENT_HOST   # LAN IP, Tailscale name, or MagicDNS
  User YOUR_USER
  # IdentityFile ~/.ssh/id_ed25519
  ForwardAgent no
  ServerAliveInterval 30
  ServerAliveCountMax 4

# Optional: Tailscale MagicDNS when off-LAN
# Host agents-ts
#   HostName agents.tailnet-name.ts.net
#   User YOUR_USER
