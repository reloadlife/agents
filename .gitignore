# binaries
/bin/
/dist/
/agentsd
/agentsctl
*.exe
*.test
*.out

# frontend (source in web/; built assets committed under internal/webui/dist)
web/node_modules/
web/dist/
# Keep embedded SPA trackable even if a global ignore has `dist/`
!internal/webui/dist/
!internal/webui/dist/**

# local runtime
.jobs/
*.db
*.db-journal
*.db-wal
*.db-shm

# secrets / local config
/etc-agentsd/
.env
.env.*
!.env.example
config.local.toml
agentsctl.local.toml
config.toml
!config.example.toml
# never commit host-specific production configs
deploy/*.personal
deploy/*personal*
**/config.agents.toml.personal

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store

# coverage
coverage.out
coverage.html
deploy/config.agents.toml.personal

# generated project maps / memory (per-workspace)
.agents/

# TS incremental
web/tsconfig.tsbuildinfo
